# BookStack
BOOKSTACK_URL=https://bookstack.example.com
BOOKSTACK_TOKEN_ID=your_token_id
BOOKSTACK_TOKEN_SECRET=your_token_secret

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=bookstack_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Host port exposed by docker compose postgres service
POSTGRES_HOST_PORT=5433

# OpenAI
OPENAI_API_KEY=sk-your-key

# Embedding provider: openai | local
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_FAIL_FAST_ON_QUOTA=true

# Optional ingestion tuning
SYNC_BATCH_SIZE=50
BOOKSTACK_REQUESTS_PER_SECOND=5
BOOKSTACK_MAX_RETRIES=4
EMBEDDING_MAX_RETRIES=4
RETRY_BACKOFF_SECONDS=1.0

# Optional Chroma connection
CHROMA_USE_HTTP=false
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=bookstack_documents
CHROMA_PATH=./chroma_data

# Groq LLM (free tier - get key at console.groq.com)
GROQ_API_KEY=gsk-your-key
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
RAG_TOP_K=5
RAG_MIN_SCORE=0.25
# API server
API_HOST=0.0.0.0
API_PORT=8080
