# ─── Environment ─────────────────────────────────────────────────────
# Options: development, staging, production, testing
ENVIRONMENT=development
DEBUG=false

# ─── Database (PostgreSQL) ───────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=bookstack_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# DB_POOL_SIZE=5
# DB_POOL_OVERFLOW=10

# Host port exposed by docker compose postgres service
POSTGRES_HOST_PORT=5433

# ─── BookStack API ───────────────────────────────────────────────────
BOOKSTACK_URL=https://bookstack.example.com
BOOKSTACK_TOKEN_ID=your_token_id
BOOKSTACK_TOKEN_SECRET=your_token_secret
# BOOKSTACK_REQUESTS_PER_SECOND=5
# BOOKSTACK_MAX_RETRIES=4
# BOOKSTACK_TIMEOUT=30

# ─── Embeddings ──────────────────────────────────────────────────────
# Options: openai, local
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_FAIL_FAST_ON_QUOTA=true
# EMBEDDING_MAX_RETRIES=4
# RETRY_BACKOFF_SECONDS=1.0

# Required only when EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-your-key
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ─── Vector Store (ChromaDB) ─────────────────────────────────────────
# CHROMA_PATH=./chroma_data
# CHROMA_COLLECTION_NAME=bookstack_documents
# CHROMA_USE_HTTP=false
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ─── Cache ───────────────────────────────────────────────────────────
# ENABLE_EMBEDDING_CACHE=true
# EMBEDDING_CACHE_TYPE=memory
# EMBEDDING_CACHE_MAX_SIZE=10000
# EMBEDDING_CACHE_REDIS_URL=redis://localhost:6379
# EMBEDDING_CACHE_TTL_SECONDS=86400
# ENABLE_QUERY_CACHE=true
# QUERY_RESULT_CACHE_TTL=3600

# ─── Ingestion ───────────────────────────────────────────────────────
SYNC_BATCH_SIZE=50
# CHUNK_SIZE=500
# CHUNK_OVERLAP=100
ENABLE_PARALLEL_PROCESSING=true
MAX_WORKERS=4

# ─── LLM / Retrieval ────────────────────────────────────────────────
# ENABLE_RERANKING=false
# RERANKER_MODEL=BAAI/bge-reranker-large
# ENABLE_LLM_GENERATION=false
# LLM_MODEL=gpt-3.5-turbo
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=500
# TOP_K_DEFAULT=5
# MAX_CONTEXT_TOKENS=2000

# ─── Chat ────────────────────────────────────────────────────────────
# ENABLE_CHAT=true
# CHAT_HISTORY_LIMIT=10
# CHAT_CONTEXT_LIMIT_TOKENS=2000

# ─── API Server ──────────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8001
# CORS_ORIGINS=*
# RATE_LIMIT_PER_MINUTE=60
# API_TITLE=BookStack RAG Query API
# API_VERSION=2.0.0

# ─── Logging ─────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
# Set to true for JSON log output (production); false for colored console (dev)
# LOG_JSON=false
